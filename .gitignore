# ============================
# Printwave Monorepo .gitignore
# ============================

# --- OS & Editor ---
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*.tmp
*.bak

# --- IDEs ---
.vscode/
.idea/
*.suo
*.user

# --- Environment / secrets (IMPORTANT: never commit these) ---
.env
.env.*
!.env.example

# --- Node / npm / pnpm ---
**/node_modules/
**/package-lock.json

# --- Next.js (frontend) ---
frontend/.next/
frontend/out/
frontend/coverage/
frontend/.pnp
frontend/.pnp.*
frontend/.turbo/
frontend/.vercel/
frontend/.cache/
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# --- pnpm lock (keep for reproducible builds) ---
# frontend/pnpm-lock.yaml  ← keep this tracked

# --- Backend ---
backend/dist/
backend/logs/
backend/tmp/
backend/*.tsbuildinfo

# --- .NET (if ever added) ---
**/bin/
**/obj/
TestResults/
*.nupkg
*.snupkg
