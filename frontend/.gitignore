coverage/

# pnpm
.pnp
.pnp.*

# Turbo / cache
.turbo/
.cache/
.vercel/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# OS
.DS_Store

# v0 sandbox internal files (if applicable)
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts
.snowflake/
.v0-trash/